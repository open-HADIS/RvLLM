# rvLLM Environment Variables
# Copy this to .env and fill in your values:
#   cp .env.example .env

# --- Server ---
RVLLM_HOST=0.0.0.0
RVLLM_PORT=8000
RUST_LOG=info

# --- Model ---
# HuggingFace model name or local path
# RVLLM_MODEL=Qwen/Qwen2.5-1.5B
# RVLLM_MAX_MODEL_LEN=2048
# RVLLM_DTYPE=auto

# --- GPU ---
# CUDA_VISIBLE_DEVICES=0
# RVLLM_GPU_MEMORY_UTILIZATION=0.90
# RVLLM_TENSOR_PARALLEL_SIZE=1

# --- Kernel directory (compiled PTX files) ---
# RVLLM_KERNEL_DIR=./kernels

# --- HuggingFace ---
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
# HF_HOME=~/.cache/huggingface

# --- vast.ai deployment ---
# VASTAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Telemetry ---
# RVLLM_DISABLE_TELEMETRY=false
# RVLLM_PROMETHEUS_PORT=9090
