// Fused SiLU*Mul + Down GEMV: warp-per-row with float4 loads.
// Each warp computes one output row. gate/up loaded from global,
// silu(gate)*up computed on the fly, dotted with weight row.
//
// Grid: (ceil(HIDDEN/8), 1, 1)  Block: (256, 1, 1)
// Shared: 8 * sizeof(float) (warp reduction scratch only)

#include <cute/tensor.hpp>
#include <cuda_fp16.h>

using namespace cute;

constexpr int HIDDEN = {{HIDDEN_SIZE}};
constexpr int INTERMEDIATE = {{INTERMEDIATE_SIZE}};
constexpr int NTHREADS = {{THREADS}};
constexpr int NWARPS = NTHREADS / 32;
constexpr int ROWS_PER_BLOCK = NWARPS;
constexpr int I8 = INTERMEDIATE / 8;

__device__ __forceinline__ float silu_f32(float x) {
    return x / (1.0f + expf(-x));
}

extern "C"
__global__ void __launch_bounds__(NTHREADS)
{{KERNEL_NAME}}(
    __half* __restrict__ output,
    const __half* __restrict__ gate,
    const __half* __restrict__ up,
    const __half* __restrict__ down_weight,
    int hidden_size,
    int intermediate_size
) {
    const int tid = threadIdx.x;
    const int warp_id = tid / 32;
    const int lane_id = tid % 32;

    const int row = blockIdx.x * ROWS_PER_BLOCK + warp_id;
    if (row >= hidden_size) return;

    // Weight row (f16 global, float4 loads)
    const float4* w_vec = reinterpret_cast<const float4*>(down_weight + row * INTERMEDIATE);
    // gate and up as float4 (f16, 8 values per load)
    const float4* g_vec = reinterpret_cast<const float4*>(gate);
    const float4* u_vec = reinterpret_cast<const float4*>(up);

    float acc = 0.0f;

    // For INTERMEDIATE=8960: I8=1120, each lane does 1120/32 = 35 iterations.
    // Each iteration: 3 float4 loads (gate, up, weight) + 8 silu + 8 mul + 8 FMA.
    // Total per lane: 35 * 8 = 280 FMAs -- massive ILP.
    #pragma unroll 4
    for (int i = lane_id; i < I8; i += 32) {
        float4 gv = __ldg(&g_vec[i]);
        float4 uv = __ldg(&u_vec[i]);
        float4 wv = __ldg(&w_vec[i]);

        const half2* gh = reinterpret_cast<const half2*>(&gv);
        const half2* uh = reinterpret_cast<const half2*>(&uv);
        const half2* wh = reinterpret_cast<const half2*>(&wv);

        #pragma unroll
        for (int j = 0; j < 4; j++) {
            float g0 = __half2float(gh[j].x), g1 = __half2float(gh[j].y);
            float u0 = __half2float(uh[j].x), u1 = __half2float(uh[j].y);
            float w0 = __half2float(wh[j].x), w1 = __half2float(wh[j].y);
            acc += silu_f32(g0) * u0 * w0 + silu_f32(g1) * u1 * w1;
        }
    }

    // Warp-only reduction
    #pragma unroll
    for (int off = 16; off > 0; off >>= 1)
        acc += __shfl_xor_sync(0xffffffff, acc, off);

    if (lane_id == 0)
        output[row] = __float2half(acc);
}
