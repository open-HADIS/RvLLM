// Fused RMSNorm + GEMV: warp-per-row with float4 loads.
// Phase 1: All 256 threads cooperate on RMSNorm into shared memory.
// Phase 2: Each warp (32 threads) independently computes one output row.
//          8 warps = 8 rows per block. Zero syncthreads in Phase 2.
//
// Grid: (ceil(OUT_DIM/8), 1, 1)  Block: (256, 1, 1)
// Shared: HIDDEN * sizeof(float) + 8 * sizeof(float)

#include <cute/tensor.hpp>
#include <cuda_fp16.h>

using namespace cute;

constexpr int HIDDEN = {{HIDDEN_SIZE}};
constexpr int OUTDIM = {{OUT_DIM}};
constexpr int NTHREADS = {{THREADS}};
constexpr int NWARPS = NTHREADS / 32;
constexpr int ROWS_PER_BLOCK = NWARPS; // 8
constexpr int H8 = HIDDEN / 8; // float4 work items per row
constexpr float RMS_EPS = {{EPS}};

extern "C"
__global__ void __launch_bounds__(NTHREADS)
{{KERNEL_NAME}}(
    __half* __restrict__ output,
    const __half* __restrict__ hidden,
    const __half* __restrict__ norm_weight,
    const __half* __restrict__ proj_weight,
    float eps,
    int hidden_size,
    int out_dim
) {
    const int tid = threadIdx.x;
    const int warp_id = tid / 32;
    const int lane_id = tid % 32;

    extern __shared__ float smem[];
    float* s_normed = smem;
    float* s_warp = smem + HIDDEN;

    // ================================================================
    // Phase 1: RMSNorm (all 256 threads cooperate)
    // ================================================================
    auto g_hidden = make_tensor(make_gmem_ptr(hidden), make_layout(Int<HIDDEN>{}));
    auto g_norm = make_tensor(make_gmem_ptr(norm_weight), make_layout(Int<HIDDEN>{}));

    float thread_sq = 0.0f;
    for (int i = tid; i < HIDDEN; i += NTHREADS) {
        float v = __half2float(g_hidden(i));
        s_normed[i] = v;
        thread_sq += v * v;
    }

    #pragma unroll
    for (int off = 16; off > 0; off >>= 1)
        thread_sq += __shfl_xor_sync(0xffffffff, thread_sq, off);
    if (lane_id == 0) s_warp[warp_id] = thread_sq;
    __syncthreads();

    if (tid == 0) {
        float total = 0.0f;
        for (int w = 0; w < NWARPS; w++) total += s_warp[w];
        s_warp[0] = total;
    }
    __syncthreads();

    float rms_scale = rsqrtf(s_warp[0] / float(HIDDEN) + RMS_EPS);

    for (int i = tid; i < HIDDEN; i += NTHREADS) {
        s_normed[i] = s_normed[i] * rms_scale * __half2float(g_norm(i));
    }
    __syncthreads();

    // ================================================================
    // Phase 2: GEMV -- warp-per-row, float4 loads, zero syncthreads
    // ================================================================
    const int row = blockIdx.x * ROWS_PER_BLOCK + warp_id;
    if (row >= out_dim) return;

    // Weight row pointer (f16 global memory, read via __ldg + float4)
    const float4* w_vec = reinterpret_cast<const float4*>(proj_weight + row * HIDDEN);
    // Normalized hidden in shared memory (f32, read via float4)
    const float4* s_vec = reinterpret_cast<const float4*>(s_normed);

    float acc = 0.0f;

    // Each lane strides over H8 = HIDDEN/8 float4 work items.
    // For HIDDEN=1536: H8=192, each lane does 192/32 = 6 iterations.
    // Each iteration: 1 float4 global load (128-bit, 8 f16 values)
    //                 2 float4 shared loads (8 f32 values)
    //                 8 FMAs
    // Total per lane: 6 * 8 = 48 FMAs -- excellent ILP.
    #pragma unroll 4
    for (int i = lane_id; i < H8; i += 32) {
        float4 w128 = __ldg(&w_vec[i]);
        const half2* hp = reinterpret_cast<const half2*>(&w128);

        float4 sv0 = s_vec[i * 2];
        float4 sv1 = s_vec[i * 2 + 1];

        acc += __half2float(hp[0].x) * sv0.x + __half2float(hp[0].y) * sv0.y
             + __half2float(hp[1].x) * sv0.z + __half2float(hp[1].y) * sv0.w
             + __half2float(hp[2].x) * sv1.x + __half2float(hp[2].y) * sv1.y
             + __half2float(hp[3].x) * sv1.z + __half2float(hp[3].y) * sv1.w;
    }

    // Warp-only reduction (no shared memory, no syncthreads)
    #pragma unroll
    for (int off = 16; off > 0; off >>= 1)
        acc += __shfl_xor_sync(0xffffffff, acc, off);

    if (lane_id == 0)
        output[row] = __float2half(acc);
}
